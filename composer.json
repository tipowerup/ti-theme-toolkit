{
    "name": "tipowerup/ti-theme-toolkit",
    "description": "Shared infrastructure package for TiPowerUp TastyIgniter themes — AbstractThemeServiceProvider, ColorHelper, BannerManager, BaseSchema and more.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tastyigniter",
        "tastyigniter-theme",
        "theme-toolkit",
        "livewire",
        "laravel"
    ],
    "homepage": "https://github.com/tipowerup/ti-theme-toolkit",
    "authors": [
        {
            "name": "TiPowerUp",
            "homepage": "https://github.com/tipowerup"
        }
    ],
    "support": {
        "issues": "https://github.com/tipowerup/ti-theme-toolkit/issues",
        "source": "https://github.com/tipowerup/ti-theme-toolkit"
    },
    "require": {
        "php": "^8.2",
        "tastyigniter/core": "^4.0",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.2",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "tipowerup/testbench": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "TiPowerUp\\ThemeToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TiPowerUp\\ThemeToolkit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TiPowerUp\\ThemeToolkit\\ToolkitServiceProvider"
            ]
        }
    },
    "scripts": {
        "test:lint": "vendor/bin/pint --test --ansi",
        "test:lint-fix": "vendor/bin/pint --ansi",
        "test:pest": "vendor/bin/pest --compact",
        "test": [
            "@test:lint",
            "@test:pest"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
